# Application
APP_NAME="Image Embedding Backend"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://embed_user:embed_pass@localhost:5433/embedding_service

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=                # Optional — only needed if Qdrant has auth enabled
QDRANT_COLLECTION_NAME=evidence_embeddings
QDRANT_VECTOR_SIZE=512           # CLIP ViT-B-32 dimension

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=                # Leave empty for local dev (no auth)

# Redis Streams (consuming output from GPU compute service)
REDIS_STREAMS_DB=3
STREAM_EVIDENCE_SEARCH=evidence:search       # Publish search requests to GPU
STREAM_EMBEDDINGS_RESULTS=embeddings:results # Consume computed vectors from GPU
STREAM_SEARCH_RESULTS=search:results         # Consume search vectors from GPU
STREAM_BACKEND_GROUP=backend-workers         # Consumer group name
STREAM_CONSUMER_BLOCK_MS=5000                # XREADGROUP block timeout
STREAM_CONSUMER_BATCH_SIZE=10                # Messages per XREADGROUP call
STREAM_RECLAIM_IDLE_MS=3600000               # Reclaim idle messages after 1h
STREAM_DEAD_LETTER_MAX_RETRIES=3             # Max retries before dead letter
STREAM_CONSUMER_CONCURRENCY=1                # Concurrent consumer threads

# Recalculation (re-run old searches against new evidence)
RECALCULATION_ENABLED=true
RECALCULATION_HOURS_OLD=2                    # Only recalculate searches older than N hours
RECALCULATION_BATCH_SIZE=20                  # Max searches per recalculation cycle

# Safety Nets (scheduled fallbacks)
STALE_WORKING_MINUTES=10                     # Reset stuck WORKING rows after N minutes
MAX_RETRIES=3                                # Max retries before marking as ERROR
CLEANUP_DAYS=30                              # Delete completed/error rows older than N days

# Storage Service (upload filtered images to MinIO)
STORAGE_SERVICE_URL=http://storage-service:8080  # Docker network DNS
# STORAGE_SERVICE_URL=http://localhost:8080     # Local dev (if storage runs on host)

# Search
DEFAULT_SIMILARITY_THRESHOLD=0.75            # Default cosine similarity threshold (0.0-1.0)
MAX_SEARCH_RESULTS=100                       # Maximum results per search
